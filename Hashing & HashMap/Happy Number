#Code:

import java.util.*;

public class Solution {

    private int sumOfSquares(int n){
        int temp = n;
        int ans = 0;
        while(temp > 0){
            ans += Math.pow(temp % 10, 2);
            temp /= 10;
        }
        return ans;
    }

    public boolean isHappy(int n) {
        //You can code here

        HashSet<Integer> set = new HashSet<>();

        while(n != 1){
            if(set.contains(n)){
                return false;
            }
            set.add(n);
            n = sumOfSquares(n);
        }

        if(n == 1){
            return true;
        }
        return true;
    }
}
