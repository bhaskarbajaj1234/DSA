class MyStack {
    class StackNode {
        int data;
        StackNode next;
        StackNode(int a) {
            data = a;
            next = null;
        }
    }   
    StackNode top; //It is our head
    
    //Function to push an integer into the stack.
    void push(int a) {
        StackNode newNode = new StackNode(a);

        newNode.next = top;
        top = newNode;
        return; 
    }
    
    //Function to remove an item from top of the stack.
    int pop() {
        if(top == null) return -1;
        int temp = top.data;
        top = top.next;

        return temp;
    }
}
