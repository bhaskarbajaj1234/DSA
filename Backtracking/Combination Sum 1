#Code:

class Solution {
    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        List<List<Integer>> ans = new ArrayList<>();
        helper(candidates, target, ans, 0, new ArrayList<>());
        return ans;
    }

    public void helper(int[] candidates, int target, List<List<Integer>> ans, int idx, ArrayList<Integer> curr){
        //Base case
        if(idx == candidates.length){
            if(target == 0){
                ans.add(new ArrayList<>(curr));
            }
            return;
        }

        //Main logic
        //Pick condition
        if(candidates[idx] <= target){
            curr.add(candidates[idx]);
            helper(candidates, target - candidates[idx], ans, idx, curr);
            curr.remove(curr.size() - 1);
        }
        //Not pick
        helper(candidates, target, ans, idx+1, curr);
    }
}
