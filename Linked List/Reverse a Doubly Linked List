class Solution {
    public ListNode reverseDLL(ListNode head) {
        // Your code goes here
        if(head == null || head.next == null){
            return head;
        }

        //swapping
        ListNode current = head;
        ListNode last = null;
        while(current != null){
            last = current.prev;
            current.prev = current.next;
            current.next = last;

            current = current.prev;
        }
        
        return last.prev;
    }
}
